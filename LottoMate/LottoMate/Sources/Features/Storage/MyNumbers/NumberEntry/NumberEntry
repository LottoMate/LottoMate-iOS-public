import UIKit

class NumberEntry: UIView {

    private var lottoNumberInputViews: [LottoNumberInputView] = []

    init() {
        super.init(frame: .zero)
        self.backgroundColor = .white
        setupInitialLottoNumberInputView()
        setupLayout()
    }
    
    required init?(coder: NSCoder) {
        fatalError("init(coder:) has not been implemented")
    }
    
    private func setupInitialLottoNumberInputView() {
        let initialLottoInputView = LottoNumberInputView()
        lottoNumberInputViews.append(initialLottoInputView)
        updateLottoNumberInputContainer()
    }
    
    private func updateLottoNumberInputContainer() {
        // Clear existing layout
        lottoNumberInputContainer.flex.removeAllItems()
        
        // Add all lotto number input views
        lottoNumberInputContainer.flex
            .direction(.column)
            .gap(16)
            .define { flex in
                for inputView in lottoNumberInputViews {
                    flex.addItem(inputView)
                }
            }
        
        // Update layout
        lottoNumberInputContainer.flex.layout(mode: .adjustHeight)
        rootFlexContainer.flex.layout(mode: .adjustHeight)
        scrollView.contentSize = rootFlexContainer.frame.size
    }
    
    private func addNewLottoNumberInputView() {
        let newLottoInputView = LottoNumberInputView()
        lottoNumberInputViews.append(newLottoInputView)
        updateLottoNumberInputContainer()
    }

    private func setupLayout() {
        // Implementation of setupLayout method
    }
} 